rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      // Keep this list identical to ADMIN_EMAILS in firebase-config.js
      return request.auth != null &&
        request.auth.token.email in [
          'your-email@gmail.com'
        ];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    match /materials/{materialId} {
      allow read: if isSignedIn() && (resource.data.status == 'approved' || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200;
      allow update, delete: if isAdmin();
    }

    match /announcements/{id} {
      // Public — no login needed to see news/links on the homepage.
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /subscribers/{id} {
      // Anyone can subscribe (even signed out); only admins can read the list,
      // so email addresses aren't publicly browsable.
      allow create: if request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\\\s]+@[^@\\\\s]+\\\\.[^@\\\\s]+$');
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
